# ================= 必填：数据库 =================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=bot
DB_PASSWORD=请填写数据库密码
DB_NAME=bot

# ================= 必填：Telegram 母平台机器人 =================
SUPER_ADMIN_ID=请填写你的Telegram数字ID
MASTER_BOT_TOKEN=请填写母平台机器人Token
SAAS_BOT_URL=https://t.me/YourSaaSBotUsername

# ================= 必填：Netts API =================
SERVER_IP=请填写Netts白名单服务器IP
NETTS_API_KEY=请填写Netts_API_Key

# ================= 可选：Netts API 地址，一般不用改 =================
NETTS_ORDER_URL_1H=https://netts.io/apiv2/order1h
NETTS_ORDER_URL_5M=https://netts.io/apiv2/order5m
NETTS_PRICING_URL=https://netts.io/apiv2/pricing
